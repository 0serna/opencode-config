{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "opencode/big-pickle",
  "model": "openai/gpt-5.4",
  "agent": {
    "main": { "color": "primary" },
    "plan": { "disable": true },
    "build": { "disable": true },
    "explore": { "disable": true }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "variants": {
            "high": { "reasoningEffort": "high" },
            "none": { "disabled": true },
            "low": { "disabled": true },
            "medium": { "disabled": true },
            "xhigh": { "disabled": true }
          }
        }
      }
    }
  },
  "mcp": {
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=true",
        "--isolated=true"
      ]
    }
  },
  "permission": {
    "*": "allow",
    "doom_loop": "ask",
    "bash": {
      "*": "allow",
      "* --help": "allow",
      "* -h": "allow",
      "* --version": "allow",
      "* -v": "allow",
      // dependencies
      "* install *": "ask",
      "* update *": "ask",
      "* add *": "ask",
      // http
      "wget *": "ask",
      "curl *": "allow",
      "curl * POST *": "ask",
      "curl * PUT *": "ask",
      "curl * PATCH *": "ask",
      "curl * DELETE *": "ask",
      // git
      "git *": "ask",
      "git clone *": "allow",
      "git help *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git commit *": "allow",
      "git rev-parse *": "allow",
      "git remote -v": "allow",
      "git grep *": "allow",
      "git ls-files *": "allow",
      "git blame *": "allow",
      // gh
      "gh *": "ask",
      "gh help *": "allow",
      "gh search *": "allow",
      "gh status *": "allow",
      "gh config get *": "allow",
      "gh config list *": "allow",
      "gh repo list *": "allow",
      "gh repo view *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr status *": "allow",
      "gh pr checks *": "allow",
      "gh pr checkout *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh issue status *": "allow",
      "gh api *": "allow",
      "gh api * POST *": "ask",
      "gh api * PUT *": "ask",
      "gh api * PATCH *": "ask",
      "gh api * DELETE *": "ask",
      // system
      "chmod *": "ask",
      "chown *": "ask"
    }
  },
  "lsp": false
}
