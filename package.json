{
  "name": "opencode-config",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "link": "tsx src/dotfiles-installer.ts",
    "test": "vitest run",
    "check": "prettier --write . && eslint --fix . && tsc --noEmit && openspec validate --all --json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opencode-ai/plugin": "^1.0.184",
    "@types/node": "^24.5.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "lint-staged": {
    "*.{ts,js,json,jsonc}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
