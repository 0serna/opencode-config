{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "system",
  "plugin": ["oc-tps@latest"],
  "keybinds": {
    "input_clear": "ctrl+d",
    "session_new": "ctrl+n",
    "session_list": "ctrl+l",
    "model_cycle_favorite": "tab",
    "model_list": "shift+tab",
    "command_list": "f2",
    "messages_undo": "ctrl+u",
    "messages_previous": "ctrl+up",
    "messages_next": "ctrl+down",
    "agent_cycle": "none",
    "terminal_suspend": "none",
    "model_cycle_recent": "none",
    "app_exit": "none"
  }
}
