{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "system",
  "plugin": ["oc-tps@0.0.6", "@slkiser/opencode-quota@3.6.2"],
  "keybinds": {
    "input_clear": "ctrl+d",
    "session_new": "ctrl+n",
    "session_list": "ctrl+l",
    "model_list": "shift+tab",
    "command_list": "f2",
    "messages_undo": "ctrl+u",
    "messages_previous": "ctrl+left",
    "messages_next": "ctrl+right",
    "model_cycle_favorite": "tab",
    "agent_cycle": "none",
    "terminal_suspend": "none",
    "model_cycle_recent": "none",
    "app_exit": "none",
  },
}
