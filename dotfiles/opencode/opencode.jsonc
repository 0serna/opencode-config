{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/qwen3.6-plus",
  "agent": {
    "main": {
      "color": "primary"
    },
    "explore": {
      "model": "opencode-go/qwen3.6-plus"
    },
    "general": {
      "model": "opencode-go/qwen3.6-plus"
    },
    "plan": {
      "disable": true
    },
    "build": {
      "disable": true
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=true",
        "--isolated=true"
      ]
    }
  },
  "permission": {
    "*": "allow",
    "doom_loop": "ask",
    "bash": {
      "*": "allow",
      "* --help": "allow",
      "* -h": "allow",
      "* --version": "allow",
      "* -v": "allow",
      // dependencies
      "* install *": "ask",
      // http
      "wget *": "ask",
      "curl *": "allow",
      "curl * POST *": "ask",
      "curl * PUT *": "ask",
      "curl * PATCH *": "ask",
      "curl * DELETE *": "ask",
      // git
      "git *": "ask",
      "git clone *": "allow",
      "git help *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git commit *": "allow",
      "git rev-parse *": "allow",
      "git remote -v": "allow",
      "git grep *": "allow",
      "git ls-files *": "allow",
      "git blame *": "allow",
      // gh
      "gh *": "ask",
      "gh help *": "allow",
      "gh search *": "allow",
      "gh status *": "allow",
      "gh release view *": "allow",
      "gh config get *": "allow",
      "gh config list *": "allow",
      "gh repo list *": "allow",
      "gh repo view *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr status *": "allow",
      "gh pr checks *": "allow",
      "gh pr checkout *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh issue status *": "allow",
      "gh api *": "allow",
      "gh api * POST *": "ask",
      "gh api * PUT *": "ask",
      "gh api * PATCH *": "ask",
      "gh api * DELETE *": "ask",
      // system
      "chmod *": "ask",
      "chown *": "ask"
    }
  },
  "lsp": false,
  "plugin": ["@slkiser/opencode-quota"],
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": false,
      "enabledProviders": "auto",
      "formatStyle": "classic",
      "percentDisplayMode": "used"
    }
  }
}
