{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "light",
  "agent": {
    "deep": {
      "mode": "primary",
      "color": "primary",
      "model": "openai/gpt-5.5",
    },
    "light": {
      "mode": "primary",
      "color": "secondary",
      "model": "opencode-go/kimi-k2.6",
    },
    "plan": {
      "disable": true,
    },
    "build": {
      "disable": true,
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
    },
    "chrome-devtools": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=true",
        "--isolated=true",
      ],
    },
  },
  "plugin": ["@slkiser/opencode-quota", "context-mode"],
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": false,
      "enabledProviders": "auto",
    },
  },
  "permission": {
    "*": "allow",
    "doom_loop": "ask",
    "bash": {
      "*": "allow",
      // help
      "* --help": "allow",
      "* -h": "allow",
      "* --version": "allow",
      "* -v": "allow",
      // system
      "chmod *": "ask",
      "chown *": "ask",
      // dependencies
      "apt install *": "ask",
      "apt update *": "ask",
      "apt upgrade *": "ask",
      "apt-get install *": "ask",
      "apt-get update *": "ask",
      "apt-get upgrade *": "ask",
      "npm install *": "ask",
      "npm update *": "ask",
      "npm upgrade *": "ask",
      "npm add *": "ask",
      "brew install *": "ask",
      "brew update *": "ask",
      "brew upgrade *": "ask",
      "pip install *": "ask",
      "pip update *": "ask",
      "pip upgrade *": "ask",
      "pip3 install *": "ask",
      "pip3 update *": "ask",
      "pip3 upgrade *": "ask",
      // http
      "wget *": "ask",
      "curl *": "allow",
      "curl * POST *": "ask",
      "curl * PUT *": "ask",
      "curl * PATCH *": "ask",
      "curl * DELETE *": "ask",
      // git
      "git *": "ask",
      "git clone *": "allow",
      "git help *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git commit *": "allow",
      "git rev-parse *": "allow",
      "git remote -v": "allow",
      "git grep *": "allow",
      "git ls-files *": "allow",
      "git blame *": "allow",
      "git check-ignore *": "allow",
      // gh
      "gh *": "ask",
      "gh help *": "allow",
      "gh search *": "allow",
      "gh status *": "allow",
      "gh release view *": "allow",
      "gh config get *": "allow",
      "gh config list *": "allow",
      "gh repo list *": "allow",
      "gh repo view *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr status *": "allow",
      "gh pr checks *": "allow",
      "gh pr checkout *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh issue status *": "allow",
      "gh api *": "allow",
      "gh api * POST *": "ask",
      "gh api * PUT *": "ask",
      "gh api * PATCH *": "ask",
      "gh api * DELETE *": "ask",
    },
  },
  "tool_output": {
    "max_lines": 5000,
    "max_bytes": 102400,
  },
  "lsp": false,
}
