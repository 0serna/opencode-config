{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "snapshot": false,
  "small_model": "opencode/minimax-m2.5-free",
  "model": "opencode/minimax-m2.5-free",
  "plugin": ["@slkiser/opencode-quota@3.6.2"],
  "agent": {
    "main": {
      "mode": "primary",
      "color": "primary",
    },
    "plan": { "disable": true },
    "build": { "disable": true },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5": {
          "variants": {
            "minimal": { "disabled": true },
            "medium": { "disabled": true },
            "high": { "disabled": true },
            "xhigh": { "disabled": true },
          },
        },
      },
    },
  },
  "permission": {
    "*": "allow",
    "doom_loop": "ask",
    "task": "deny", // subagents
    "todowrite": "deny", // todo list
    "bash": {
      "*": "allow",
      // help
      "* --help": "allow",
      "* --version": "allow",
      // system
      "chmod *": "ask",
      "chown *": "ask",
      "sudo *": "deny",
      // dependencies
      "apt *": "ask",
      "apt-get *": "ask",
      "brew *": "ask",
      "pip *": "ask",
      "pip3 *": "ask",
      "npm list *": "allow",
      "npm * -g *": "ask",
      "npm * --global *": "ask",
      // http
      "wget *": "ask",
      "curl *": "allow",
      "curl * POST *": "ask",
      "curl * PUT *": "ask",
      "curl * PATCH *": "ask",
      "curl * DELETE *": "ask",
      // git
      "git *": "ask",
      "git clone *": "allow",
      "git help *": "allow",
      "rtk git status *": "allow",
      "git diff *": "allow",
      "rtk git log *": "allow",
      "rtk git show *": "allow",
      "rtk git commit *": "allow",
      "git rev-parse *": "allow",
      "git remote -v": "allow",
      "git grep *": "allow",
      "git ls-files *": "allow",
      "git ls-tree *": "allow",
      "git blame *": "allow",
      "git check-ignore *": "allow",
      "git --no-pager *": "allow",
      // gh
      "gh *": "ask",
      "gh help *": "allow",
      "gh search *": "allow",
      "gh status *": "allow",
      "rtk gh release view *": "allow",
      "gh config get *": "allow",
      "gh config list *": "allow",
      "rtk gh repo clone *": "allow",
      "rtk gh repo list *": "allow",
      "rtk gh repo view *": "allow",
      "rtk gh pr view *": "allow",
      "rtk gh pr diff *": "allow",
      "rtk gh pr list *": "allow",
      "rtk gh pr status *": "allow",
      "rtk gh pr checks *": "allow",
      "rtk gh pr checkout *": "allow",
      "rtk gh issue list *": "allow",
      "rtk gh issue view *": "allow",
      "rtk gh issue status *": "allow",
      "rtk gh api *": "allow",
      "rtk gh api * POST *": "ask",
      "rtk gh api * PUT *": "ask",
      "rtk gh api * PATCH *": "ask",
      "rtk gh api * DELETE *": "ask",
    },
  },
}
